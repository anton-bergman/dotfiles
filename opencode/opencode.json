{
  "$schema": "https://opencode.ai/config.json",
  // ============================================================================
  // CORE SETTINGS
  // ============================================================================
  "model": "google/gemini-3-flash",
  "theme": "my-theme", // Default: "opencode"
  "formatter": false, // Default: true
  "autoupdate": true,
  // ============================================================================
  // SECURITY
  // ============================================================================
  "permission": {
    "read": {
      "*": "allow" // Default
    },
    "bash": {
      "*": "allow", // Default
      "rm -rf*": "ask",
      "sudo*": "ask",
      "git push*": "ask",
      "git commit*": "ask",
      "git add*": "ask"
    }
  },
  // ============================================================================
  // PERFORMANCE
  // ============================================================================
  "watcher": {
    // Default: [] (no ignores)
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".git/**",
      "*.log"
    ]
  },
  // ============================================================================
  // CUSTOM COMMANDS
  // ============================================================================
  // Default: {} (no custom commands)
  "command": {
    "test": {
      "template": "Run the test suite with coverage and analyze failures",
      "description": "Run tests with coverage"
    },
    "review": {
      "template": "Review git diff for code quality, bugs, and best practices",
      "description": "Review changes",
      "agent": "plan"
    }
  },
  // ============================================================================
  // PROJECT INSTRUCTIONS
  // ============================================================================
  // Default: [] (no instructions)
  "instructions": ["AGENTS.md"]
}
